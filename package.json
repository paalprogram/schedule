{
  "name": "scheduleapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npx tsx src/db/migrate.ts",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:reset": "npx tsx src/db/migrate.ts && npx tsx src/db/seed.ts -- --confirm",
    "db:backup": "npx tsx src/db/backup.ts create",
    "db:backups": "npx tsx src/db/backup.ts list",
    "db:restore": "npx tsx src/db/backup.ts restore"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.5",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
